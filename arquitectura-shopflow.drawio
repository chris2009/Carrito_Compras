        <mxCell id="stripe-wh" value="🔔 Webhooks&lt;br/&gt;&lt;font style=&quot;font-size:10px&quot;&gt;checkout.session.completed&lt;br/&gt;Notifica al servidor del pago&lt;br/&gt;→ POST /api/webhooks/stripe&lt;br/&gt;Firma verificada con HMAC&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
